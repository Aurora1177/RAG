# Template only: copy to ".env" and fill values. Never put real API keys in this file or commit secrets.
#
# Difference from .env:
#   .env.example — safe template for the repo (no real keys); teammates copy it to .env.
#   .env         — your machine’s real config (keys, paths); keep private and out of git if possible.

# 百炼 / DashScope — get key from Alibaba Cloud Model Studio (百炼控制台)
DASHSCOPE_API_KEY=

BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen3 examples (enable in console): qwen3-30b-a3b, qwen3-32b, qwen3-14b, qwen3-max, qwen3-8b, ...
MODEL=qwen3-30b-a3b
GRADE_MODEL=qwen3-30b-a3b

MILVUS_HOST=localhost
# On Windows, if health shows disconnected while Docker Milvus is running, try:
# MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
# Optional: full URI overrides host/port (e.g. Zilliz Cloud).
# MILVUS_URI=https://...
# Linux/macOS embedded DB (not supported on Windows): MILVUS_LOCAL_PATH=./data/milvus_lite.db
MILVUS_COLLECTION=rag_new_kb
# Default is chroma (local PersistentClient, same idea as rag/main.ipynb). Set milvus only if you run Milvus.
# VECTOR_BACKEND=chroma
# VECTOR_BACKEND=milvus
# CHROMA_PERSIST_PATH=
# CHROMA_COLLECTION=rag_new_kb
DENSE_EMBEDDING_DIM=1024

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# If huggingface.co is unreachable, use a mirror (e.g. China):
HF_ENDPOINT=https://hf-mirror.com

# Default knowledge file if POST /ingest/doc has no body.path (repo layout: vibecoding/rag/doc.md)
KNOWLEDGE_DOC_PATH=

LEAF_RETRIEVE_LEVEL=3
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2

# Optional rerank (e.g. Jina AI OpenAI-compatible /v1/rerank). If any of these is empty, rerank is skipped.
# RERANK_BINDING_HOST=https://api.jina.ai
# RERANK_API_KEY=
# RERANK_MODEL=jina-reranker-v2-base-multilingual

# SQLite parent-chunk store (default). Override with postgresql+psycopg2://... if needed.
# DATABASE_URL=
